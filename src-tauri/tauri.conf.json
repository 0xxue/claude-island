{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Island",
  "version": "0.1.0",
  "identifier": "com.claude-island.app",
  "build": {
    "frontendDist": "../src/island"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Island",
        "width": 56,
        "height": 56,
        "x": null,
        "y": 8,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
